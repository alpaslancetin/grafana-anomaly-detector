{
  "target_dynamic_rules": 300,
  "duration_seconds": 1800,
  "sample_interval_seconds": 30,
  "initial_settle_seconds": 20,
  "warmup_samples_to_ignore": 1,
  "grafana_base_url": "http://localhost:3000",
  "exporter_base_url": "http://localhost:9110",
  "prometheus_base_url": "http://localhost:9091",
  "basic_auth": {
    "user": "",
    "password": ""
  },
  "headers": {},
  "dashboard_checks": [
    {
      "name": "demo_dashboard_page",
      "url": "http://localhost:3000/d/anomaly-detector-demo/provisioned-anomaly-detector-demo?orgId=1&from=now-6h&to=now"
    }
  ],
  "render_checks": [
    {
      "name": "demo_panel_render",
      "url": "http://localhost:3000/render/d-solo/anomaly-detector-demo/provisioned-anomaly-detector-demo?orgId=1&panelId=1&from=now-6h&to=now&width=1200&height=700"
    }
  ],
  "prometheus_queries": [
    {
      "name": "rule_score_count",
      "expr": "count(grafana_anomaly_rule_score)"
    },
    {
      "name": "series_score_count",
      "expr": "count(grafana_anomaly_score)"
    }
  ],
  "alert_queries": [
    {
      "name": "alert_ready_signal",
      "expr": "max_over_time(grafana_anomaly_rule_score[5m])"
    }
  ],
  "safety_thresholds": {
    "max_eval_seconds": 1.5,
    "min_scrape_success": 1.0,
    "max_exporter_metrics_latency_seconds": 0.25,
    "max_dashboard_latency_seconds": 2.0,
    "max_render_latency_seconds": 15.0
  }
}
