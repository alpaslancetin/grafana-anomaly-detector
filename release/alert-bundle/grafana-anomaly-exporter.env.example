ANOMALY_CONFIG_PATH=/etc/grafana-anomaly-exporter/config.yml
ANOMALY_DYNAMIC_RULES_PATH=/var/lib/grafana-anomaly-exporter/dynamic_rules.json
ANOMALY_PROMETHEUS_URL=http://127.0.0.1:9090
ANOMALY_LISTEN_HOST=127.0.0.1
ANOMALY_LISTEN_PORT=9110
ANOMALY_EVALUATION_INTERVAL_SECONDS=10
ANOMALY_REQUEST_TIMEOUT_SECONDS=10
ANOMALY_CONFIG_RELOAD_INTERVAL_SECONDS=10
