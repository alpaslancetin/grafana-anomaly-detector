        "h": 14,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 2,
      "options": {
        "title": "xmpp_p2p | elastic-ml-xmpp-p2p",
        "setupMode": "recommended",
        "metricPreset": "traffic",
        "detectionMode": "single",
        "algorithm": "mad",
        "sensitivity": 2.8,
        "baselineWindow": 12,
        "seasonalitySamples": 24,
        "seasonalRefinement": "cycle",
        "severityPreset": "warning_first",
        "bucketSpan": "auto",
        "maxAnomalies": 6,
        "showBands": true,
        "showExpectedLine": true,
        "showSummary": true,
        "showExports": false,
        "showInlineSeriesLabels": true,
