        "timeAxisPlacement": "top_and_bottom",
        "markerShapeMode": "severity",
        "scoreFeedMode": "auto",
        "scoreFeedEndpoint": "http://192.168.51.45:9110",
        "scoreFeedRuleNamePrefix": "bip_devops_xmpp_p2p_elastic_ml_xmpp_p2p"
